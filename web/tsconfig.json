{
	"compilerOptions": {
		"lib": [
			"ESNext",
			"dom"
		],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noFallthroughCasesInSwitch": true,
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"removeComments": true,
		"strict": true,
		"target": "ESNext",
		"types": []
	},
	"include": ["./**/*.ts"]
}