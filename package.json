{
  "name": "git-graph-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run server:dev\" \"bun run web:dev\"",
    "server:dev": "bun --watch server/index.ts",
    "web:dev": "bunx --bun vite",
    "build": "bunx --bun vite build",
    "start": "bun server/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "iconv-lite": "^0.7.2",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/iconv-lite": "^0.0.1",
    "concurrently": "^8.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0",
    "vite": "^8.0.2",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
